      <span class="token tag"><span class="token tag"><span class="token punctuation">&lt;</span>node-ref</span> <span class="token attr-name"><span class="token namespace">oor:</span>name</span><span class="token attr-value"><span class="token punctuation attr-equals">=</span><span class="token punctuation">"</span>Writer1<span class="token punctuation">"</span></span> <span class="token attr-name"><span class="token namespace">oor:</span>node-type</span><span class="token attr-value"><span class="token punctuation attr-equals">=</span><span class="token punctuation">"</span>Leaf<span class="token punctuation">"</span></span> <span class="token punctuation">/&gt;</span></span>

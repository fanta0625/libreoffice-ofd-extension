@charset "utf-8";

.rcshowhideanons { display: none; }

.rcshowhideliu { display: none; }

#footer-places-about { display: none; }

#mw-missingsummary { padding: 1em; margin: 1em 0px; border: 3px solid rgb(255, 0, 0); background: rgb(216, 216, 216); }

#mw-read-only-warning { padding: 1em; margin: 1em 0px; border: 3px solid rgb(255, 0, 0); background: rgb(216, 216, 216); }

.permissions-errors { padding: 1em; margin: 1em 0px; border: 3px solid rgb(255, 0, 0); background: rgb(216, 216, 216); }

.page-Special_RecentChanges .mw-rollback-link { display: none; }

.lang { background: rgb(249, 249, 249); border: 1px solid rgb(233, 233, 233); font-size: smaller; margin: 0px 0px 1em; padding: 0.5em 1em; }

.lang ul { display: inline; margin-left: 0px; padding-left: 0px; }

.lang ul li { border-left: 1px solid rgb(228, 228, 228); display: inline; list-style: none; margin-left: 0px; padding: 0px 0.5em; }

.lang ul li.lang_main { border-left: none; display: inline; list-style: none; margin-left: 0px; padding-left: 0px; }

.lang ul a.external { background: none !important; padding-right: 0px !important; }

.lang ul li.lang_title { display: none; }

div.mw-geshi { padding: 1em; margin: 1em 0px; border: 1px dashed rgb(47, 111, 171); background-color: rgb(249, 249, 249); }

ol.references li:target, sup.reference:target, span.citation:target { background-color: rgb(221, 238, 255); }

body.action-info :target, .citation:target { background-color: rgba(0, 127, 255, 0.133); }

div#content a[href$=".pdf"].external, div#content a[href*=".pdf?"].external, div#content a[href*=".pdf#"].external, div#content a[href$=".PDF"].external, div#content a[href*=".PDF?"].external, div#content a[href*=".PDF#"].external, div#mw_content a[href$=".pdf"].external, div#mw_content a[href*=".pdf?"].external, div#mw_content a[href*=".pdf#"].external, div#mw_content a[href$=".PDF"].external, div#mw_content a[href*=".PDF?"].external, div#mw_content a[href*=".PDF#"].external { background: url("/images/a/a6/PDF.png") right center / 16px no-repeat; padding-right: 17px; }

.wikiEditor-ui-toolbar .group .tool-select .menu .options { z-index: 100 !important; }

div#content a[href*="openoffice.org"].external, div#mw_content a[href*="openoffice.org"].external { background: url("/images/0/03/OpenOffice_Favicon.png") right center / 1em no-repeat; padding-right: 1em; }

.icontable td img { max-width: 100px; }

.index-column-1 { max-width: 480px; grid-area: index-column-1; }

.index-column-2 { max-width: 480px; grid-area: index-column-2; }

@supports (grid-area:auto) {
  @media screen and (min-width: 1200px) {
  .index { display: grid; grid-template-columns: 480px 480px; grid-template-rows: minmax(1em, auto) minmax(1em, auto) 1fr; grid-template-areas: "index-column-1 index-column-2"; }
  .index-column-2 { margin-left: 10px; }
}
}

div.mw-pt-languages { border: 1px solid rgb(202, 222, 237); margin: 5px 0px; box-shadow: rgb(221, 230, 237) 0px 1px 3px; background: linear-gradient(rgb(255, 255, 255) 65%, rgb(239, 246, 250) 100%); clear: both; font-size: 88%; }

div.mw-pt-languages-label { background: none; border: none; width: 10%; }

.infobox { border: 1px solid rgb(162, 169, 177); border-spacing: 3px; box-shadow: rgba(0, 0, 0, 0.1) 0px 1px 3px; background-color: rgb(249, 249, 249); color: black; margin: 0.5em 0px 0.5em 1em; padding: 0.2em; float: right; clear: right; font-size: 88%; line-height: 1.5em; }

.infobox caption { font-size: 125%; font-weight: bold; padding: 0.2em; text-align: center; }

.infobox td, .infobox th { vertical-align: top; text-align: left; }

.menuitem { background: rgba(166, 251, 255, 0.45); border: 1px solid deepskyblue; box-decoration-break: clone; border-radius: 3px; font-weight: bolder; padding: 0px 2px; white-space: nowrap; }

.button { padding: 0px 3px; border-width: 1px; border-style: solid; border-image: initial; border-color: rgb(170, 170, 170) rgb(85, 85, 85) rgb(85, 85, 85) rgb(170, 170, 170); border-radius: 2px; background: linear-gradient(rgb(252, 252, 252), rgb(224, 224, 224)) rgb(242, 242, 242); }

.publications th { background: rgb(253, 233, 169); line-height: 3rem; padding: 0px 3rem; }

[style*="--aspect-ratio"] > :first-child { width: 100%; }

[style*="--aspect-ratio"] > img { height: auto; }

@supports (--custom:property) {
  [style*="--aspect-ratio"] { position: relative; }
  [style*="--aspect-ratio"]::before { content: ""; display: block; padding-bottom: calc(100% / (var(--aspect-ratio))); }
  [style*="--aspect-ratio"] > :first-child { position: absolute; top: 0px; left: 0px; height: 100%; }
}

.dataTables_length, .dataTables_filter { width: auto !important; }

.dataTables_filter { float: left !important; margin-left: 50px; }

.releasegrid { display: grid; grid-template-columns: repeat(24, 10px); width: 240px; border: 1px solid gray; background-color: rgb(192, 192, 192); background-image: linear-gradient(to right, transparent 50%, rgba(255, 255, 255, 0.5) 50%); background-size: 20px; }

.release { grid-column-start: var(--start,1); grid-column-end: var(--end,1); grid-row: var(--row,1); background-color: var(--bg); text-align: center; padding: 10px 0px; }

pre, code { white-space: pre-wrap !important; }

code[class*="language-none"] { word-break: break-word; }

@media screen and (max-width: 767px) {
  li, code, a[href*="https://git.libreoffice.org/core/commit"] { overflow-wrap: break-word; }
}

.mw-body-content a.external.free { overflow-wrap: anywhere; }

.consent-button { background-color: rgb(39, 174, 96); border-radius: 8px; border-style: none; color: rgb(255, 255, 255); cursor: pointer; font-size: 16px; font-weight: 600; padding: 13px 20px; text-align: center; }

.consent-button:hover { background-color: rgb(30, 132, 73); }

.mw-parser-output img { max-width: 100%; height: auto; }

.mw-logo { min-width: 10rem; }

video { display: block; max-width: 87vw; }

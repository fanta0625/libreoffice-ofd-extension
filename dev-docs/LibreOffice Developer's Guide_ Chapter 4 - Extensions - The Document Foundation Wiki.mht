  <span class="token tag"><span class="token tag"><span class="token punctuation">&lt;</span>identifier</span> <span class="token attr-name">value</span><span class="token attr-value"><span class="token punctuation attr-equals">=</span><span class="token punctuation">"</span>com.mycompany.extensions.my_extension<span class="token punctuation">"</span></span> <span class="token punctuation">/&gt;</span></span>

